generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Better Auth models ----
// Generated by `npx @better-auth/cli generate` but pinned here for clarity.

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  designs       InvitationDesign[]
  assets        Asset[]
  editEvents    EditEvent[]
  auditLogs     AdminAuditLog[]
  templates     DesignTemplate[]
  billing       BillingTransaction[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---- davety domain models ----

model InvitationDesign {
  id              String   @id @default(cuid())
  userId          String
  slug            String   @unique
  vanityPath      String?  @unique
  customDomain    String?  @unique
  status          String   @default("draft") // "draft" | "published" | "archived"
  doc             Json
  publishedDoc    Json?
  // Optional bcrypt hash. When set, the public render gates entry behind a
  // password prompt. Null means open access (default behaviour).
  passwordHash    String?
  // When the invitation should be auto-archived. Set on publish based on
  // plan tier (free: +30 days, paid: configurable). archivedAt is the
  // timestamp the archive job actually ran.
  expiresAt       DateTime?
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastAutosavedAt DateTime @default(now())
  publishedAt     DateTime?

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  events   EditEvent[]
  assets   Asset[]
  guests   Guest[]
  memories MemoryEntry[]
  billing  BillingTransaction[]

  @@index([userId])
  @@index([expiresAt])
  @@index([customDomain])
  @@map("invitation_design")
}

// Stripe Checkout sonrası tier yükseltme idempotent kayıdı. session_id
// unique → webhook iki kez gelse bile çift publish yok. amount kuruş
// cinsinden saklanır (TRY * 100).
model BillingTransaction {
  id                    String    @id @default(cuid())
  userId                String
  designId              String
  stripeSessionId       String    @unique
  stripePaymentIntentId String?   @unique
  tier                  String // "basic" | "pro" | "premium"
  amount                Int // kuruş
  currency              String    @default("try")
  status                String    @default("pending") // pending | paid | refunded | failed
  promotionCode         String?
  appliedPercent        Int       @default(0)
  createdAt             DateTime  @default(now())
  paidAt                DateTime?

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  design InvitationDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
  @@index([userId])
  @@index([status])
  @@map("billing_transaction")
}

model EditEvent {
  id        String   @id @default(cuid())
  designId  String
  actorId   String
  op        String
  payload   Json
  createdAt DateTime @default(now())

  design InvitationDesign @relation(fields: [designId], references: [id], onDelete: Cascade)
  actor  User             @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([designId, createdAt])
  @@map("edit_event")
}

model Asset {
  id          String   @id @default(cuid())
  userId      String
  designId    String?
  url         String
  key         String   @unique
  // For images, keys for the responsive variants (thumb/md/lg). Null for
  // video/audio/gif. Used for precise R2 cleanup on asset deletion so we
  // do not need to ListObjects to find the variants.
  variantKeys Json?
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  design InvitationDesign? @relation(fields: [designId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([designId])
  @@map("asset")
}

model Guest {
  id          String   @id @default(cuid())
  designId    String
  name        String
  phone       String?
  email       String?
  attending   String   // "yes" | "no" | "maybe"
  guestCount  Int      @default(1)
  note        String?
  source      String?  // "whatsapp" | "qr" | "link" | "token"
  // Personalization token used in /i/[slug]/[token] links. nanoid(16),
  // unique per design. Optional because legacy guests created before the
  // feature shipped will not have one.
  token       String?  @unique
  // Plus-one allowance for this guest. When > 1 the RSVP form lets the
  // guest bring up to N companions.
  plusOneMax  Int      @default(1)
  // Group label ("aile", "iş arkadaşları", "üniversite") for filtering
  // and per-group event invitation.
  groupLabel  String?
  // Which event days the guest is invited to. Empty array means all
  // events (the default for backwards compatibility).
  eventDays   String[] @default([])
  createdAt   DateTime @default(now())

  design InvitationDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId, createdAt])
  @@index([designId, attending])
  @@map("guest")
}

model MemoryEntry {
  id         String   @id @default(cuid())
  designId   String
  authorName String
  message    String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  design InvitationDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId, createdAt])
  @@map("memory_entry")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@map("admin_audit_log")
}

model DesignTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  previewUrl  String?
  doc         Json
  category    String?
  published   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([published, updatedAt])
  @@map("design_template")
}

/// Curated background music catalog. Hosts pick a track during the editor
/// music tab and the published invitation auto-plays it (muted by default
/// with a small unmute control). All entries must be license-cleared, the
/// `licensor` and `licenseUrl` fields exist so we can prove provenance.
model MusicTrack {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  artist      String
  url         String
  /// Curated mood tags ("romantic", "joyful", "elegant"). Used by the
  /// music picker for filtering. Stored as plain string array for now,
  /// a junction table is overkill at catalog size.
  moods       String[] @default([])
  /// Tier gate: which plan can use this track. "free" means available to
  /// everyone. Higher tiers may unlock premium tracks later.
  tier        String   @default("free")
  durationSec Int?
  licensor    String?
  licenseUrl  String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled, tier])
  @@map("music_track")
}
