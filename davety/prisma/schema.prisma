generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Better Auth models ----
// Generated by `npx @better-auth/cli generate` but pinned here for clarity.

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  designs       InvitationDesign[]
  assets        Asset[]
  editEvents    EditEvent[]
  auditLogs     AdminAuditLog[]
  templates     DesignTemplate[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---- davety domain models ----

model InvitationDesign {
  id              String   @id @default(cuid())
  userId          String
  slug            String   @unique
  vanityPath      String?  @unique
  customDomain    String?  @unique
  status          String   @default("draft") // "draft" | "published"
  doc             Json
  publishedDoc    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastAutosavedAt DateTime @default(now())
  publishedAt     DateTime?

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events   EditEvent[]
  assets   Asset[]
  guests   Guest[]
  memories MemoryEntry[]

  @@index([userId])
  @@map("invitation_design")
}

model EditEvent {
  id        String   @id @default(cuid())
  designId  String
  actorId   String
  op        String
  payload   Json
  createdAt DateTime @default(now())

  design InvitationDesign @relation(fields: [designId], references: [id], onDelete: Cascade)
  actor  User             @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([designId, createdAt])
  @@map("edit_event")
}

model Asset {
  id        String   @id @default(cuid())
  userId    String
  designId  String?
  url       String
  key       String   @unique
  mimeType  String
  sizeBytes Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  design InvitationDesign? @relation(fields: [designId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([designId])
  @@map("asset")
}

model Guest {
  id          String   @id @default(cuid())
  designId    String
  name        String
  phone       String?
  email       String?
  attending   String   // "yes" | "no"
  guestCount  Int      @default(1)
  note        String?
  source      String?  // "whatsapp" | "qr" | "link"
  createdAt   DateTime @default(now())

  design InvitationDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId, createdAt])
  @@map("guest")
}

model MemoryEntry {
  id         String   @id @default(cuid())
  designId   String
  authorName String
  message    String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  design InvitationDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId, createdAt])
  @@map("memory_entry")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@map("admin_audit_log")
}

model DesignTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  previewUrl  String?
  doc         Json
  category    String?
  published   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([published, updatedAt])
  @@map("design_template")
}
