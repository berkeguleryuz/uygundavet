{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@davety/schema": ["../schema/src/index.ts"],
      "@davety/schema/*": ["../schema/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
